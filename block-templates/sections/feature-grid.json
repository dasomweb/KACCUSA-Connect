{
  "template_name": "feature-grid-v1",
  "version": "1.0",
  "description": "3-column feature grid with icons, titles, and descriptions",
  "blocks": [
    {
      "blockName": "kadence/rowlayout",
      "attrs": {
        "uniqueID": "dw_feature_grid_001",
        "columns": 3,
        "colLayout": "equal",
        "paddingType": "px",
        "topPadding": 80,
        "bottomPadding": 80,
        "columnGap": 24,
        "backgroundColor": "var(--dw-color-ui-surface)"
      },
      "innerBlocks": [
        {
          "blockName": "kadence/column",
          "attrs": {
            "padding": ["24px", "24px", "24px", "24px"],
            "background": "var(--dw-color-ui-background)",
            "borderRadius": "12px",
            "shadow": "var(--dw-shadow-card)"
          },
          "innerBlocks": [
            {
              "blockName": "kadence/icon",
              "attrs": {
                "size": 48,
                "color": "var(--dw-color-brand-accent)"
              }
            },
            {
              "blockName": "kadence/advancedheading",
              "attrs": {
                "level": 3,
                "color": "var(--dw-color-text-primary)",
                "fontSize": [22, 20, 18],
                "fontFamily": "Noto Sans KR"
              }
            },
            {
              "blockName": "kadence/advancedheading",
              "attrs": {
                "htmlTag": "p",
                "color": "var(--dw-color-text-secondary)",
                "fontSize": [16, 15, 14]
              }
            }
          ]
        },
        {
          "blockName": "kadence/column",
          "attrs": {
            "padding": ["24px", "24px", "24px", "24px"],
            "background": "var(--dw-color-ui-background)",
            "borderRadius": "12px",
            "shadow": "var(--dw-shadow-card)"
          },
          "innerBlocks": [
            {
              "blockName": "kadence/icon",
              "attrs": { "size": 48, "color": "var(--dw-color-brand-accent)" }
            },
            {
              "blockName": "kadence/advancedheading",
              "attrs": { "level": 3, "color": "var(--dw-color-text-primary)", "fontSize": [22, 20, 18] }
            },
            {
              "blockName": "kadence/advancedheading",
              "attrs": { "htmlTag": "p", "color": "var(--dw-color-text-secondary)", "fontSize": [16, 15, 14] }
            }
          ]
        },
        {
          "blockName": "kadence/column",
          "attrs": {
            "padding": ["24px", "24px", "24px", "24px"],
            "background": "var(--dw-color-ui-background)",
            "borderRadius": "12px",
            "shadow": "var(--dw-shadow-card)"
          },
          "innerBlocks": [
            {
              "blockName": "kadence/icon",
              "attrs": { "size": 48, "color": "var(--dw-color-brand-accent)" }
            },
            {
              "blockName": "kadence/advancedheading",
              "attrs": { "level": 3, "color": "var(--dw-color-text-primary)", "fontSize": [22, 20, 18] }
            },
            {
              "blockName": "kadence/advancedheading",
              "attrs": { "htmlTag": "p", "color": "var(--dw-color-text-secondary)", "fontSize": [16, 15, 14] }
            }
          ]
        }
      ]
    }
  ]
}
