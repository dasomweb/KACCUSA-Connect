{
  "template_name": "community-card-v1",
  "version": "1.1",
  "description": "Query Loop card design for community posts - references component tokens",
  "card_design": {
    "wrapper": {
      "background": "#FFFFFF",
      "border": "#E5E7EB",
      "borderRadius": 12,
      "shadow": [{"color": "rgba(0,0,0,0.08)", "blur": 16, "spread": 0, "inset": false}],
      "overflow": "hidden"
    },
    "thumbnail": {
      "aspectRatio": "16/9",
      "objectFit": "cover",
      "borderRadius": 0
    },
    "content": {
      "topPadding": [24, 20, 16],
      "bottomPadding": [24, 20, 16],
      "leftPadding": [24, 20, 16],
      "rightPadding": [24, 20, 16]
    },
    "badge": {
      "field": "_dw_region",
      "background": "#EFF6FF",
      "color": "#0F3460",
      "fontSize": [12, 12, 11],
      "fontWeight": 500,
      "borderRadius": 999,
      "padding": "3px 10px",
      "marginBottom": [12, 10, 8]
    },
    "title": {
      "tag": "h3",
      "color": "#1A1A2E",
      "fontSize": [20, 18, 16],
      "fontWeight": 700,
      "marginBottom": [8, 8, 6]
    },
    "meta": {
      "fields": ["_dw_event_date", "_dw_location"],
      "color": "#4B5563",
      "fontSize": [14, 14, 13],
      "marginBottom": [16, 12, 10]
    },
    "link_button": {
      "text": "View Details",
      "color": "#0F3460",
      "fontSize": [14, 14, 13],
      "fontWeight": 500
    }
  },
  "hover": {
    "shadow": [{"color": "rgba(0,0,0,0.1)", "blur": 15, "spread": 0, "inset": false}],
    "transform": "translateY(-2px)",
    "transition": "all 0.2s ease"
  }
}
