            },
            {
              "blockName": "kadence/advancedheading",
              "attrs": { "htmlTag": "p", "color": "#4B5563", "fontSize": [15, 15, 14], "lineHeight": [1.7, 1.7, 1.7] }
            }
          ]
        },
        {
          "blockName": "kadence/column",
          "attrs": {
            "borderRadius": [12, 12, 12],
