{
  "template_name": "feature-grid-v1",
  "version": "1.1",
  "description": "3-column feature grid with icons, titles, and descriptions",
  "background": "light",
  "blocks": [
    {
      "blockName": "kadence/rowlayout",
      "attrs": {
        "uniqueID": "dw_feature_grid_001",
        "columns": 3,
        "colLayout": "equal",

        "topPadding": [80, 60, 40],
        "bottomPadding": [80, 60, 40],
        "topPaddingType": "px",
        "bottomPaddingType": "px",

        "leftPadding": [0, 0, 20],
        "rightPadding": [0, 0, 20],
        "leftPaddingType": "px",
        "rightPaddingType": "px",

        "backgroundColor": "#F8F9FA",
        "borderRadius": 0,
        "columnGap": [24, 20, 16]
      },
      "innerBlocks": [
        {
          "blockName": "kadence/column",
          "attrs": {
            "borderRadius": [12, 12, 12],
            "background": "#FFFFFF",
            "shadow": [{"color": "rgba(0,0,0,0.08)", "blur": 16, "spread": 0, "inset": false}],
            "topPadding": [24, 20, 20],
            "bottomPadding": [24, 20, 20],
            "leftPadding": [24, 20, 16],
            "rightPadding": [24, 20, 16]
          },
          "innerBlocks": [
            {
              "blockName": "kadence/icon",
              "attrs": {
                "size": [48, 40, 36],
                "color": "#0F3460"
              }
            },
            {
              "blockName": "kadence/advancedheading",
              "attrs": {
                "level": 3,
                "color": "#1A1A2E",
                "fontSize": [22, 20, 18],
                "lineHeight": [1.3, 1.3, 1.3],
                "fontFamily": "Noto Sans KR",
                "fontWeight": "700",
                "marginBottom": [12, 10, 10]
              }
            },
            {
              "blockName": "kadence/advancedheading",
              "attrs": {
                "htmlTag": "p",
                "color": "#4B5563",
                "fontSize": [15, 15, 14],
                "lineHeight": [1.7, 1.7, 1.7]
              }
            }
          ]
        },
        {
          "blockName": "kadence/column",
          "attrs": {
            "borderRadius": [12, 12, 12],
            "background": "#FFFFFF",
            "shadow": [{"color": "rgba(0,0,0,0.08)", "blur": 16, "spread": 0, "inset": false}],
            "topPadding": [24, 20, 20],
            "bottomPadding": [24, 20, 20],
