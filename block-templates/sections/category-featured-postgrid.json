{
  "template_name": "category-featured-postgrid-v1",
  "version": "1.0",
  "description": "Category section: 1 large featured post (left postgrid) + 4 small posts (right postgrid 2x2)",
  "background": "white",
  "composite": true,
  "configurable": {
    "category_id": "required - WP category term_id",
    "category_label": "required - display name"
  },
  "left_block": {
    "blockName": "kadence/postgrid",
    "attrs": {
      "uniqueID": "dw_cf_left_{{category_slug}}",
      "postType": "post",
      "postsToShow": 1,
      "categories": [],
      "layout": "grid",
      "postColumns": [1, 1, 1],
      "alignImage": "above",
      "imageRatio": "4:3",
      "displayImage": true,
      "displayTitle": true,
      "titleFont": [
        {
          "size": ["26px", "22px", "20px"],
          "lineHeight": [1.2, 1.3, 1.3],
          "weight": "700",
          "family": "",
          "color": "palette8"
        }
      ],
      "displayAboveCategories": true,
      "aboveColor": "palette3",
      "aboveFont": [{ "size": ["11px", "11px", "10px"], "weight": "700", "textTransform": "uppercase", "family": "" }],
      "displayDate": true,
      "displayAuthor": true,
      "metaColor": "palette4",
      "metaFont": [{ "size": ["13px", "12px", "12px"], "family": "" }],
      "displayExcerpt": true,
      "excerptCustomLength": true,
      "excerptLength": 35,
      "excerptColor": "palette4",
      "excerptFont": [{ "size": ["15px", "14px", "14px"], "lineHeight": [1.7, 1.7, 1.7], "family": "" }],
      "displayShadow": false,
      "borderRadius": [0, 0, 0, 0],
      "containerPadding": [0, 0, 0, 0],
      "bodyPadding": [0, 0, 0, 0]
    }
  },
  "right_block": {
    "blockName": "kadence/postgrid",
    "attrs": {
      "uniqueID": "dw_cf_right_{{category_slug}}",
      "postType": "post",
      "postsToShow": 4,
      "offsetQuery": 1,
      "categories": [],
      "layout": "grid",
      "postColumns": [2, 2, 1],
      "columnGap": 20,
      "rowGap": 20,
      "alignImage": "above",
      "imageRatio": "3:2",
      "displayImage": true,
      "displayTitle": true,
      "titleFont": [
        {
          "size": ["15px", "14px", "14px"],
          "lineHeight": [1.3, 1.4, 1.4],
          "weight": "600",
          "family": "",
          "color": "palette8"
        }
      ],
      "displayAboveCategories": true,
      "aboveColor": "palette3",
      "aboveFont": [{ "size": ["11px", "10px", "10px"], "weight": "700", "textTransform": "uppercase", "family": "" }],
      "displayDate": true,
      "metaColor": "palette4",
      "metaFont": [{ "size": ["12px", "11px", "11px"], "family": "" }],
      "displayExcerpt": true,
      "excerptCustomLength": true,
      "excerptLength": 15,
      "excerptColor": "palette4",
      "excerptFont": [{ "size": ["13px", "12px", "12px"], "lineHeight": [1.5, 1.5, 1.5], "family": "" }],
      "displayShadow": false,
      "borderRadius": [0, 0, 0, 0],
      "containerPadding": [0, 0, 0, 0],
      "bodyPadding": [0, 0, 0, 0]
    }
  }
}
