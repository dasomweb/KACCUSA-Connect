{
  "template_name": "magazine-hero-v1",
  "version": "1.0",
  "description": "Magazine hero: featured postgrid with large image, centered text, overlay style",
  "background": "white",
  "blockName": "kadence/postgrid",
  "attrs": {
    "uniqueID": "dw_mag_hero",
    "postType": "post",
    "postsToShow": 1,
    "allowSticky": true,
    "layout": "grid",
    "postColumns": [1, 1, 1],
    "columnGap": 0,
    "rowGap": 0,
    "alignImage": "beside",
    "imageRatio": "3:4",
    "displayImage": true,
    "imageFullHeight": true,
    "displayTitle": true,
    "titleFont": [
      {
        "size": ["28px", "24px", "20px"],
        "lineHeight": [1.2, 1.3, 1.3],
        "weight": "700",
        "family": "",
        "color": "palette8"
      }
    ],
    "displayAboveCategories": true,
    "aboveColor": "palette3",
    "aboveFont": [
      {
        "size": ["12px", "11px", "11px"],
        "weight": "700",
        "textTransform": "uppercase",
        "family": ""
      }
    ],
    "displayDate": true,
    "displayAuthor": true,
    "metaColor": "palette4",
    "metaFont": [
      {
        "size": ["13px", "12px", "12px"],
        "family": ""
      }
    ],
    "displayExcerpt": true,
    "excerptCustomLength": true,
    "excerptLength": 25,
    "excerptColor": "palette4",
    "excerptFont": [
      {
        "size": ["15px", "14px", "14px"],
        "lineHeight": [1.7, 1.7, 1.7],
        "family": ""
      }
    ],
    "contentAlign": "center",
    "backgroundColor": "",
    "containerPadding": [20, 20, 20, 20],
    "displayShadow": false,
    "borderRadius": [0, 0, 0, 0]
  }
}
