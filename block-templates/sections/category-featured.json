{
  "template_name": "category-featured-v1",
  "version": "1.0",
  "description": "Category section: 1 large featured post left + 4 small cards right (2x2 grid)",
  "background": "white",
  "markup": true,
  "config": {
    "category_slug": "{{category}}",
    "category_label": "{{CATEGORY}}",
    "posts_per_page": 5
  },
  "blocks": [
    {
      "blockName": "kadence/rowlayout",
      "attrs": {
        "uniqueID": "dw_cat_feat_{{category}}",
        "columns": 1,
        "topPadding": [40, 30, 24],
        "bottomPadding": [40, 30, 24],
        "leftPadding": [0, 0, 20],
        "rightPadding": [0, 0, 20],
        "maxWidth": 1200,
        "align": "full",
        "bgColor": "palette7"
      },
      "innerBlocks": [
        {
          "blockName": "kadence/column",
          "innerBlocks": [
            {
              "blockName": "kadence/rowlayout",
              "comment": "Header: category title + view all",
              "attrs": {
                "uniqueID": "dw_cf_header_{{category}}",
                "columns": 2,
                "bottomPadding": [16, 12, 10],
                "borderBottom": "1px solid var(--global-palette6)"
              },
              "innerBlocks": [
                {
                  "blockName": "kadence/column",
                  "innerBlocks": [
                    {
                      "blockName": "kadence/advancedheading",
                      "attrs": {
                        "content": "{{CATEGORY}}",
                        "level": 2,
                        "colorPalette": "palette8",
                        "fontSize": [16, 15, 14],
                        "fontWeight": "700",
                        "letterSpacing": "0.05em",
                        "textTransform": "uppercase"
                      }
                    }
                  ]
                },
                {
                  "blockName": "kadence/column",
                  "attrs": { "textAlign": "right" },
                  "innerBlocks": [
                    {
                      "blockName": "kadence/advancedheading",
                      "attrs": {
                        "content": "<a href='/category/{{category}}/'>View all &raquo;</a>",
                        "htmlTag": "p",
                        "colorPalette": "palette3",
                        "fontSize": [14, 13, 13],
                        "fontWeight": "500",
                        "align": "right"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "blockName": "kadence/rowlayout",
              "comment": "Content: large post left + 2x2 grid right",
              "attrs": {
                "uniqueID": "dw_cf_content_{{category}}",
                "columns": 2,
                "firstColumnWidth": 55,
                "columnGap": [24, 20, 16],
                "topPadding": [24, 20, 16]
              },
              "innerBlocks": [
                {
                  "blockName": "kadence/column",
                  "comment": "Large featured post",
                  "innerBlocks": [
                    {
                      "blockName": "core/query",
                      "attrs": {
                        "queryId": 20,
                        "query": { "perPage": 1, "postType": "post", "taxQuery": { "category": [] } },
                        "displayLayout": { "type": "list" }
                      },
                      "innerBlocks": [
                        {
                          "blockName": "core/post-template",
                          "innerBlocks": [
                            { "blockName": "core/post-featured-image", "attrs": { "isLink": true, "aspectRatio": "4/3", "style": { "border": { "radius": "0px" } } } },
                            { "blockName": "core/post-terms", "attrs": { "term": "category", "style": { "typography": { "fontSize": "11px", "fontWeight": "700", "textTransform": "uppercase" }, "color": { "text": "var(--global-palette3)" } } } },
                            { "blockName": "core/post-title", "attrs": { "level": 2, "isLink": true, "style": { "typography": { "fontSize": "26px", "fontWeight": "700", "lineHeight": "1.2" } } } },
                            { "blockName": "core/post-excerpt", "attrs": { "moreText": "", "excerptLength": 40, "style": { "typography": { "fontSize": "15px", "lineHeight": "1.7" }, "color": { "text": "var(--global-palette4)" } } } },
                            { "blockName": "core/post-date", "attrs": { "style": { "typography": { "fontSize": "13px" }, "color": { "text": "var(--global-palette4)" } } } }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "blockName": "kadence/column",
                  "comment": "2x2 grid of small posts",
                  "innerBlocks": [
                    {
                      "blockName": "core/query",
                      "attrs": {
                        "queryId": 21,
                        "query": { "perPage": 4, "offset": 1, "postType": "post", "taxQuery": { "category": [] } },
                        "displayLayout": { "type": "flex", "columns": 2 }
                      },
                      "innerBlocks": [
                        {
                          "blockName": "core/post-template",
                          "innerBlocks": [
                            { "blockName": "core/post-featured-image", "attrs": { "isLink": true, "aspectRatio": "16/9", "style": { "border": { "radius": "0px" } } } },
                            { "blockName": "core/post-terms", "attrs": { "term": "category", "style": { "typography": { "fontSize": "11px", "fontWeight": "700", "textTransform": "uppercase" }, "color": { "text": "var(--global-palette3)" } } } },
                            { "blockName": "core/post-title", "attrs": { "level": 4, "isLink": true, "style": { "typography": { "fontSize": "15px", "fontWeight": "600", "lineHeight": "1.3" } } } },
                            { "blockName": "core/post-excerpt", "attrs": { "moreText": "", "excerptLength": 15, "style": { "typography": { "fontSize": "13px" }, "color": { "text": "var(--global-palette4)" } } } },
                            { "blockName": "core/post-date", "attrs": { "style": { "typography": { "fontSize": "12px" }, "color": { "text": "var(--global-palette4)" } } } }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
