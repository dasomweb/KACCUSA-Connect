{
  "template_name": "cta-section-v1",
  "version": "1.1",
  "description": "Full-width call-to-action section with centered text and button",
  "background": "dark",
  "blocks": [
    {
      "blockName": "kadence/rowlayout",
      "attrs": {
        "uniqueID": "dw_cta_001",
        "columns": 1,
        "colLayout": "equal",

        "topPadding": [80, 60, 40],
        "bottomPadding": [80, 60, 40],
        "topPaddingType": "px",
        "bottomPaddingType": "px",

        "leftPadding": [0, 0, 20],
        "rightPadding": [0, 0, 20],
        "leftPaddingType": "px",
        "rightPaddingType": "px",

        "backgroundColor": "#1A1A2E",
        "borderRadius": 0,
        "textAlign": "center"
      },
      "innerBlocks": [
        {
          "blockName": "kadence/column",
          "innerBlocks": [
            {
              "blockName": "kadence/advancedheading",
              "attrs": {
                "level": 2,
                "color": "#FFFFFF",
                "fontSize": [36, 28, 24],
                "lineHeight": [1.2, 1.2, 1.3],
                "fontFamily": "Noto Sans KR",
                "fontWeight": "700",
                "align": "center",
                "marginBottom": [16, 12, 10]
              }
            },
            {
              "blockName": "kadence/advancedheading",
              "attrs": {
                "level": 3,
                "htmlTag": "p",
                "color": "#FFFFFF",
                "fontSize": [18, 16, 15],
                "lineHeight": [1.7, 1.7, 1.7],
                "align": "center",
                "marginBottom": [32, 24, 20]
              }
            },
            {
              "blockName": "kadence/advancedbtn",
              "attrs": {
                "hAlign": "center",
                "btns": [
                  {
                    "text": "Join Now",
                    "color": "#1A1A2E",
                    "background": "#FFFFFF",
                    "borderRadius": 6,
                    "paddingLR": 24,
                    "paddingBT": 12,
                    "fontSize": [15, 15, 14]
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
